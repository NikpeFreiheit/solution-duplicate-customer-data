@startuml
!include https://raw.githubusercontent.com/plantuml-stdlib/C4-PlantUML/master/C4_Component.puml
LAYOUT_WITH_LEGEND()

' Standard configuration for compatibility
set separator none

title Component Diagram

' External Systems
Person_Ext(partner, "Partner", "External system that transmits data to the company's system")
System_Ext(ssn_service, "SSN Service", "Service with the ability to verify identity by SSN")

' System Boundary
System_Boundary(cms_boundary, "Application Normalization and Validation Service") {
    Component(normalization_service, "Normalization Service", "Software System", "Performs data normalization according to defined rules.")
    Component(validation_service, "Application Validation and Grouping Service", "Software System", "Validates applications by comparing them against existing data in the system based on defined rules and groups duplicate applications together.")
    Component(api,"API Gateway",,)
    Component(mongo, "Raw Applications Store", "MongoDB", "Database for store non-normalized applications")
}
System_Boundary(crm_monolith, "Monolithic CRM System (UI + Backend)"){
    Component(crm, "CRM (Backend)", "Software System", "System for managing applications, contacts, contracts, and customer profiles.")
    Component(ui, "UI", "Software System", "System for managing and enters applications.")
}

' Containers
Container(db, "Database", "Postgres","Storage of normalized and validated data from the CRM system")
Person(employee, "Company Employee", "Communicates with the client. Enters applications into the system.")

' Relationships
Rel(employee, ui, "Creation and management of applications, retrieval of client data, and client verification")

Rel(ui, crm, "Create applications")
Rel(ui, employee, "Retrieve client data for communication, verification, and duplicate confirmation")

Rel(partner, api, "Submit application for creation", "JSON/HTTP")
Rel(api, mongo, "POST to storage", "JSON/HTTP")

Rel(mongo, normalization_service, "Normalize submitted application", "JSON/HTTP")

Rel(normalization_service, validation_service, "Validate and group submitted applications", "JSON/HTTP")
Rel(validation_service, db, "Stores validated applications, checks for duplicates, and persists suspected duplicates for manual review")
Rel(validation_service, crm, "Duplicate confirmation required", "JSON/HTTP")

Rel(crm, ssn_service, "SSN verification request", "JSON/HTTP")
Rel(crm, db, "Saving SSN verification information")
Rel(crm, ui,  "Duplicate confirmation required")
Rel(crm, mongo,  "Create applications", "JSON/HTTP")



@enduml